{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WARDEN Staff",
  "version": "1.0.0",
  "identifier": "com.warden.staff",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/llama-server"
    ],
    "resources": [
      "binaries/gemma-4-e2b.gguf",
      "binaries/*.dll"
    ]
  }
}
